# VUUP Server — environment variables
# Copy to .env and fill in real values before running in production.

# REQUIRED in production: HMAC secret for JWT signing (32+ chars, random)
# In dev, a default is used — do NOT use the default in production.
AUTH_SECRET=replace-this-with-a-random-32-char-secret-in-production

# SQLite database file path. Defaults to ./data/vuup.db if unset.
# Use :memory: for ephemeral/test mode.
# DB_PATH=./data/vuup.db

# HTTP port (default: 3001)
# PORT=3001

# Set to 'production' to enable strict OTP verification (vs dev 6-digit bypass)
# NODE_ENV=production

# Dev-only OTP shortcut. When 'true' (AND NODE_ENV is not production), /auth/login
# accepts ANY 6-digit code and /auth/otp-request uses the fixed code 123456.
# NEVER set this in production — leaving it unset/false enforces the strict,
# single-use, expiring OTP that must match the code from /auth/otp-request.
# AUTH_DEV_OTP=true

# Comma-separated list of allowed CORS origins (production frontend domains).
# localhost dev/preview origins are always allowed. Example:
# CORS_ORIGINS=https://vuup.app,https://www.vuup.app
